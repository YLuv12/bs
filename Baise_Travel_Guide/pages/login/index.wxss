.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F6F8 100%);
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
}

.login-header {
  text-align: center;
  padding: 80rpx 0 60rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(230, 67, 64, 0.3);
}

.logo-icon {
  font-size: 60rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 10rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #8A8AA3;
}

.login-tabs {
  display: flex;
  background: #F5F6F8;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #8A8AA3;
  transition: all 0.3s;
}

.tab-item.active {
  background: #FFFFFF;
  color: #E64340;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tab-icon {
  margin-right: 10rpx;
  font-size: 32rpx;
}

.login-content {
  flex: 1;
}

.wechat-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160 0%, #00a854 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.wechat-btn::after {
  border: none;
}

.btn-icon {
  margin-right: 16rpx;
  font-size: 36rpx;
}

.login-tip {
  text-align: center;
  font-size: 24rpx;
  color: #8A8AA3;
  margin-top: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 30rpx;
  background: #F5F6F8;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input.error {
  border-color: #FF4D4F;
  background: #FFF2F0;
}

.password-input {
  position: relative;
}

.password-input .form-input {
  padding-right: 100rpx;
}

.toggle-pwd {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  padding: 10rpx;
}

.error-tip {
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 10rpx;
  height: 0;
  opacity: 0;
  transition: all 0.3s;
}

.error-tip.show {
  height: auto;
  opacity: 1;
}

.pwd-strength-wrap {
  margin-top: 16rpx;
}

.pwd-strength {
  display: flex;
  align-items: center;
}

.strength-bar {
  display: flex;
  gap: 8rpx;
}

.bar-item {
  width: 60rpx;
  height: 6rpx;
  background: #E0E0E0;
  border-radius: 3rpx;
  transition: all 0.3s;
}

.pwd-strength.weak .bar-item.active {
  background: #FF4D4F;
}

.pwd-strength.middle .bar-item.active {
  background: #FAAD14;
}

.pwd-strength.strong .bar-item.active {
  background: #52C41A;
}

.strength-text {
  margin-left: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.form-tip {
  font-size: 22rpx;
  color: #8A8AA3;
  margin-top: 10rpx;
}

.agreement {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin: 30rpx 0;
  font-size: 24rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #D0D0D0;
  border-radius: 8rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
  transition: all 0.3s;
}

.checkbox.checked {
  background: #E64340;
  border-color: #E64340;
}

.agreement-text {
  color: #8A8AA3;
}

.agreement-link {
  color: #E64340;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}

.switch-register {
  text-align: center;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #E64340;
}

.nickname-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.nickname-picker.show {
  opacity: 1;
  visibility: visible;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.nickname-picker.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.picker-close {
  font-size: 48rpx;
  color: #8A8AA3;
  line-height: 1;
}

.picker-avatar-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #E64340;
  margin-bottom: 16rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #8A8AA3;
}

.wx-nickname-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #F5F6F8;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.wx-nickname-left {
  display: flex;
  align-items: center;
}

.wx-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.wx-label {
  font-size: 28rpx;
  color: #1A1A2E;
}

.wx-nickname-right {
  display: flex;
  align-items: center;
}

.wx-nickname-value {
  font-size: 28rpx;
  color: #8A8AA3;
  margin-right: 10rpx;
}

.arrow {
  font-size: 32rpx;
  color: #8A8AA3;
}

.nickname-input-row {
  margin-bottom: 40rpx;
}

.nickname-input {
  width: 100%;
  height: 96rpx;
  padding: 0 30rpx;
  background: #F5F6F8;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.picker-actions {
  display: flex;
  gap: 20rpx;
}

.picker-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.picker-btn::after {
  border: none;
}

.picker-btn.skip {
  background: #F5F6F8;
  color: #8A8AA3;
}

.picker-btn.confirm {
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  color: #FFFFFF;
}
