.page { min-height: 100vh; background: var(--bg-gray); padding-bottom: 140rpx; }
.banner { width: 100%; height: 400rpx; }
.banner-img { width: 100%; height: 100%; }
.main-info { background: var(--bg); padding: 30rpx; margin-bottom: 20rpx; }
.title-row { display: flex; justify-content: space-between; align-items: flex-start; }
.title { flex: 1; font-size: 40rpx; font-weight: 600; color: var(--text); }
.action-btns { display: flex; gap: 20rpx; }
.action-btn { display: flex; flex-direction: column; align-items: center; font-size: 22rpx; color: var(--text-secondary); }
.action-icon { font-size: 40rpx; margin-bottom: 4rpx; }
.tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx; }
.tag { font-size: 22rpx; padding: 6rpx 16rpx; background: rgba(230, 67, 64, 0.1); color: #E64340; border-radius: 8rpx; }
.stats { display: flex; gap: 30rpx; margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid var(--border); }
.stat-item { display: flex; align-items: center; font-size: 24rpx; color: var(--text-light); }
.star { color: #FFB800; font-size: 24rpx; margin-right: 4rpx; }
.rating-num { font-size: 32rpx; font-weight: 600; color: var(--text); margin-right: 4rpx; }
.rating-count { font-size: 22rpx; color: var(--text-light); }
.section { background: var(--bg); padding: 30rpx; margin-bottom: 20rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--text); }
.section-action { font-size: 26rpx; color: var(--primary); }
.info-list { display: flex; flex-direction: column; gap: 24rpx; }
.info-item { display: flex; align-items: flex-start; }
.info-icon { font-size: 32rpx; margin-right: 16rpx; width: 40rpx; text-align: center; }
.info-content { flex: 1; }
.info-label { font-size: 24rpx; color: var(--text-light); margin-bottom: 4rpx; }
.info-value { font-size: 28rpx; color: var(--text); }
.info-action { font-size: 24rpx; color: var(--primary); padding: 4rpx 16rpx; background: rgba(230, 67, 64, 0.1); border-radius: 8rpx; }
.description { font-size: 28rpx; color: var(--text-secondary); line-height: 0.9; }
.rating-row { display: flex; align-items: center; gap: 16rpx; }
.rating-stars.interactive .star { font-size: 40rpx; color: #DDD;}
.rating-stars.interactive .star.active { color: #FFB800; }
.rating-text { font-size: 36rpx; font-weight: 600; color: var(--primary); }
.comments { display: flex; flex-direction: column; gap: 24rpx; }
.comment-item { display: flex; }
.comment-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0; }
.comment-content { flex: 1; }
.comment-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.comment-name { font-size: 28rpx; font-weight: 500; color: var(--text); }
.comment-rating .star { font-size: 20rpx; }
.comment-text { font-size: 28rpx; color: var(--text-secondary); line-height: 1.6; margin-bottom: 8rpx; }
.comment-footer { display: flex; justify-content: space-between; align-items: center; }
.comment-time { font-size: 22rpx; color: var(--text-light); }
.comment-like { display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; color: var(--text-light); }
.empty-comment { text-align: center; padding: 40rpx; color: var(--text-light); font-size: 26rpx; }
.bottom-bar { position: fixed; left: 0; right: 0; bottom: 0; background: var(--bg); display: flex; align-items: center; padding: 20rpx 30rpx; box-shadow: 0 -4rpx 20rpx var(--shadow); z-index: 100; }
.bar-btn { display: flex; flex-direction: column; align-items: center; padding: 0 30rpx; font-size: 22rpx; color: var(--text-secondary); }
.bar-btn.done { color: #52C41A; }
.bar-btn.active { color: var(--primary); }
.bar-icon { font-size: 36rpx; margin-bottom: 4rpx; }
.nav-btn { flex: 1; height: 80rpx; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); border-radius: 40rpx; display: flex; align-items: center; justify-content: center; color: #FFFFFF; font-size: 30rpx; font-weight: 500; margin-left: 30rpx; border: none; }
.nav-btn::after { border: none; }
.nav-icon { margin-right: 8rpx; }
.back-top { position: fixed; right: 30rpx; bottom: 220rpx; width: 80rpx; height: 80rpx; border-radius: 50%; background: #F0F0F0; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1); display: flex; align-items: center; justify-content: center; z-index: 100; transition: all 0.3s ease; animation: pulse 2s ease-in-out infinite; }
.back-top.show { opacity: 1; visibility: visible; }
.back-top.hide { opacity: 0; visibility: hidden; pointer-events: none; }
.back-top-icon { width: 40rpx; height: 40rpx; }
.share-panel { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; visibility: hidden; }
.share-panel.show { visibility: visible; }
.share-mask { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); }
.share-content { position: absolute; left: 0; right: 0; bottom: 0; background: var(--bg); border-radius: 24rpx 24rpx 0 0; padding: 40rpx 30rpx; padding-bottom: env(safe-area-inset-bottom); transform: translateY(100%); transition: transform 0.3s ease; }
.share-panel.show .share-content { transform: translateY(0); }
.share-item { display: flex; align-items: center; padding: 30rpx; font-size: 32rpx; color: var(--text); }
.share-icon { font-size: 40rpx; margin-right: 20rpx; }
.share-cancel { text-align: center; padding: 30rpx; margin-top: 20rpx; font-size: 32rpx; color: var(--text-light); border-top: 1rpx solid var(--border); }
.loading-page { display: flex; align-items: center; justify-content: center; min-height: 100vh; color: var(--text-light); }

@keyframes pulse {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.05);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}
