.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 50%, #FFF0F0 100%);
}

.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(180deg, #FFFFFF 0%, rgba(255,255,255,0.95) 100%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.header-content {
  padding: 24rpx 32rpx;
}

.header-title {
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
}

.title-line {
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #E64340 0%, #FF6B6B 100%);
  border-radius: 3rpx;
  margin-top: 12rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: rgba(230, 67, 64, 0.06);
  border-radius: 40rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.search-box:focus-within {
  background: #FFFFFF;
  border-color: #E64340;
  box-shadow: 0 0 0 4rpx rgba(230, 67, 64, 0.1);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.clear-icon {
  font-size: 36rpx;
  color: #8A8AA3;
  padding: 0 10rpx;
}

.search-input {
  flex: 1;
  width: 450rpx;
  height: 80rpx;
  font-size: 28rpx;
  background: transparent;
}

.filter-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.3);
}

.filter-icon {
  font-size: 32rpx;
  color: #FFFFFF;
}

.category-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #8A8AA3;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.category-item.active {
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.3);
}

.list-content {
  padding: 24rpx 32rpx;
}

.food-item {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 67, 64, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.food-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.12);
}

.item-visual {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.item-img {
  width: 100%;
  height: 100%;
}

.item-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  display: flex;
  justify-content: flex-end;
}

.item-rating {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
}

.rating-star {
  color: #FFB800;
  font-size: 24rpx;
}

.rating-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.item-info {
  padding: 24rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.item-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-right: 16rpx;
}

.item-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #E64340;
  font-weight: 600;
}

.price-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #E64340;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, rgba(230, 67, 64, 0.1) 0%, rgba(255, 107, 107, 0.1) 100%);
  color: #E64340;
  border-radius: 16rpx;
  font-weight: 500;
}

.item-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #8A8AA3;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.footer-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.footer-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.footer-label {
  font-size: 22rpx;
  color: #8A8AA3;
}

.footer-icon {
  font-size: 24rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #8A8AA3;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #8A8AA3;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

@keyframes pulse {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.05);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.reach-bottom {
  text-align: center;
  padding: 48rpx 0;
  font-size: 26rpx;
  color: #8A8AA3;
}

.back-top {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
  visibility: hidden;
  transform: scale(0.8);
  animation: pulse 2s ease-in-out infinite;
}

.back-top.show {
  opacity: 1;
  visibility: visible;
  transform: scale(1);
}

.back-top.hide {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: scale(0.8);
}

.back-top-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-top-icon text {
  color: #666666;
  font-size: 36rpx;
  font-weight: 700;
}

.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  visibility: hidden;
}

.filter-panel.show {
  visibility: visible;
}

.filter-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.filter-content {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 75%;
  background: #FFFFFF;
  padding: 32rpx;
  box-sizing: border-box;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.filter-panel.show .filter-content {
  transform: translateX(0);
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.filter-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.filter-clear {
  font-size: 28rpx;
  color: #E64340;
  font-weight: 500;
}

.filter-section {
  padding: 32rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.filter-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 20rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  padding: 16rpx 28rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #4A4A68;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.active {
  background: rgba(230, 67, 64, 0.1);
  color: #E64340;
  border-color: #E64340;
}

.filter-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.filter-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.filter-btn.cancel {
  background: rgba(0, 0, 0, 0.03);
  color: #4A4A68;
}

.filter-btn.confirm {
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(230, 67, 64, 0.3);
}
