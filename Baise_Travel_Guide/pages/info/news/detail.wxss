.page { min-height: 100vh; background: #F5F6F8; }

.cover { 
  width: 100%; 
  height: 400rpx; 
}

.content { 
  padding: 30rpx; 
  background: #FFFFFF;
  min-height: calc(100vh - 400rpx);
}

.title { 
  font-size: 36rpx; 
  font-weight: 600; 
  color: #1A1A2E; 
  line-height: 1.4; 
  margin-bottom: 20rpx; 
}

.meta { 
  display: flex; 
  gap: 20rpx; 
  font-size: 24rpx; 
  color: #8A8AA3; 
  margin-bottom: 20rpx; 
  padding-bottom: 20rpx; 
  border-bottom: 1rpx solid #EAEAEA; 
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  padding: 8rpx 16rpx;
  background: rgba(229, 57, 53, 0.1);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #E53935;
}

.article { 
  font-size: 30rpx; 
  color: #333333; 
  line-height: 1.8; 
}

.article image {
  max-width: 100%;
  height: auto;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

.loading { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  min-height: 100vh; 
  color: #8A8AA3; 
}
