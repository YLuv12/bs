.page { min-height: 100vh; background: var(--bg-gray); }
.header { background: var(--bg); padding: 20rpx 30rpx; position: sticky; top: 0; z-index: 100; }
.search-row { display: flex; align-items: center; gap: 20rpx; }
.search-box { flex: 1; display: flex; align-items: center; height: 80rpx; padding: 0 24rpx; background: var(--bg-gray); border-radius: 40rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.5; }
.search-input { flex: 1; height: 80rpx; font-size: 28rpx; }
.search-btn { padding: 0 30rpx; height: 80rpx; display: flex; align-items: center; background: var(--primary); border-radius: 40rpx; color: #FFFFFF; font-size: 28rpx; }
.content { padding: 20rpx; }
.section { background: var(--bg); border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: var(--text); }
.section-clear { font-size: 26rpx; color: var(--text-light); }
.keywords { display: flex; flex-wrap: wrap; gap: 16rpx; }
.keyword-item { padding: 12rpx 24rpx; background: var(--bg-gray); border-radius: 20rpx; font-size: 26rpx; color: var(--text-secondary); }
.keyword-item.hot { background: rgba(230, 67, 64, 0.1); color: var(--primary); }
.tabs { display: flex; background: var(--bg); border-radius: 20rpx; padding: 8rpx; margin-bottom: 20rpx; }
.tab-item { flex: 1; height: 72rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: var(--text-secondary); border-radius: 16rpx; }
.tab-item.active { background: var(--primary); color: #FFFFFF; }
.loading { text-align: center; padding: 60rpx; color: var(--text-light); }
.results { background: var(--bg); border-radius: 20rpx; overflow: hidden; }
.result-item { display: flex; padding: 24rpx; border-bottom: 1rpx solid var(--border); }
.result-item:last-child { border-bottom: none; }
.result-img { width: 160rpx; height: 120rpx; border-radius: 12rpx; flex-shrink: 0; }
.result-content { flex: 1; margin-left: 20rpx; position: relative; }
.result-title { font-size: 30rpx; font-weight: 500; color: var(--text); margin-bottom: 10rpx; }
.result-info { display: flex; gap: 20rpx; font-size: 24rpx; color: var(--text-light); }
.result-info .rating { color: #FFB800; }
.result-info .price { color: var(--primary); }
.result-type { position: absolute; right: 0; top: 0; font-size: 20rpx; padding: 4rpx 12rpx; background: rgba(230, 67, 64, 0.1); color: var(--primary); border-radius: 6rpx; }
.result-type.food { background: rgba(255, 153, 0, 0.1); color: #FF9900; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; color: var(--text-light); }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.5; }
