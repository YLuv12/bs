.page { min-height: 100vh; background: #F5F6F8; }

.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FFFFFF;
  gap: 20rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F6F8;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon { font-size: 32rpx; margin-right: 16rpx; }

.search-input { flex: 1; font-size: 28rpx; }

.clear-icon {
  font-size: 36rpx;
  color: #8A8AA3;
  padding: 0 10rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #E53935 0%, #FF6B6B 100%);
  border-radius: 40rpx;
  color: #FFFFFF;
  font-size: 28rpx;
}

.history-section {
  padding: 30rpx;
  background: #FFFFFF;
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title { font-size: 30rpx; font-weight: 500; color: #1A1A2E; }

.clear-text { font-size: 26rpx; color: #8A8AA3; }

.history-list { display: flex; flex-wrap: wrap; gap: 16rpx; }

.history-item {
  padding: 12rpx 24rpx;
  background: #F5F6F8;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666666;
}

.result-section { padding: 20rpx; }

.loading {
  text-align: center;
  padding: 60rpx;
  color: #8A8AA3;
}

.result-group {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.group-title {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F6F8;
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A2E;
}

.title-icon { margin-right: 12rpx; }

.count { font-size: 24rpx; color: #8A8AA3; margin-left: 8rpx; }

.result-list { }

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F6F8;
}

.result-item:last-child { border-bottom: none; }

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-content {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.item-rating { font-size: 24rpx; color: #E53935; }

.item-price { font-size: 24rpx; color: #FF9800; }

.item-address {
  font-size: 22rpx;
  color: #8A8AA3;
  margin-top: 6rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-arrow {
  font-size: 36rpx;
  color: #D0D0D0;
  margin-left: 10rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }

.empty-text { font-size: 30rpx; color: #1A1A2E; margin-bottom: 12rpx; }

.empty-tip { font-size: 26rpx; color: #8A8AA3; }
