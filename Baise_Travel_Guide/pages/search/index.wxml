<view class="page">
  <view class="header">
    <view class="search-row">
      <view class="search-box">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="{{lang === 'zh' ? '搜索景点/美食/商户' : 'Search...'}}" value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" focus="{{true}}"/>
      </view>
      <view class="search-btn" bindtap="onSearch">{{lang === 'zh' ? '搜索' : 'Search'}}</view>
    </view>
  </view>

  <view class="content" wx:if="{{!searched}}">
    <view class="section" wx:if="{{history.length > 0}}">
      <view class="section-header">
        <text class="section-title">{{lang === 'zh' ? '搜索历史' : 'History'}}</text>
        <text class="section-clear" bindtap="clearHistory">{{lang === 'zh' ? '清空' : 'Clear'}}</text>
      </view>
      <view class="keywords">
        <view class="keyword-item" wx:for="{{history}}" wx:key="index" bindtap="onHistoryTap" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">{{lang === 'zh' ? '热门搜索' : 'Hot Searches'}}</text>
      </view>
      <view class="keywords">
        <view class="keyword-item hot" wx:for="{{hotKeywords}}" wx:key="index" bindtap="onHotTap" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="content" wx:if="{{searched}}">
    <view class="tabs">
      <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">{{lang === 'zh' ? '全部' : 'All'}}</view>
      <view class="tab-item {{activeTab === 'attraction' ? 'active' : ''}}" bindtap="switchTab" data-tab="attraction">{{lang === 'zh' ? '景点' : 'Attractions'}}</view>
      <view class="tab-item {{activeTab === 'food' ? 'active' : ''}}" bindtap="switchTab" data-tab="food">{{lang === 'zh' ? '美食' : 'Food'}}</view>
    </view>

    <view class="loading" wx:if="{{loading}}">{{lang === 'zh' ? '搜索中...' : 'Searching...'}}</view>

    <view class="results" wx:if="{{!loading}}">
      <block wx:if="{{activeTab === 'all' || activeTab === 'attraction'}}">
        <view class="result-item" wx:for="{{attractions}}" wx:key="id" bindtap="goToAttraction" data-id="{{item.id}}">
          <image class="result-img" src="{{item.image}}" mode="aspectFill"/>
          <view class="result-content">
            <view class="result-title">{{lang === 'zh' ? item.name : item.nameEn}}</view>
            <view class="result-info">
              <text class="rating">★ {{item.rating}}</text>
              <text class="region">{{item.region}}</text>
            </view>
            <view class="result-type">{{lang === 'zh' ? '景点' : 'Attraction'}}</view>
          </view>
        </view>
      </block>

      <block wx:if="{{activeTab === 'all' || activeTab === 'food'}}">
        <view class="result-item" wx:for="{{foods}}" wx:key="id" bindtap="goToFood" data-id="{{item.id}}">
          <image class="result-img" src="{{item.image}}" mode="aspectFill"/>
          <view class="result-content">
            <view class="result-title">{{lang === 'zh' ? item.name : item.nameEn}}</view>
            <view class="result-info">
              <text class="rating">★ {{item.rating}}</text>
              <text class="price">¥{{item.price}}</text>
            </view>
            <view class="result-type food">{{lang === 'zh' ? '美食' : 'Food'}}</view>
          </view>
        </view>
      </block>

      <view class="empty" wx:if="{{attractions.length === 0 && foods.length === 0}}">
        <text class="empty-icon">🔍</text>
        <text>{{lang === 'zh' ? '暂无搜索结果' : 'No results found'}}</text>
      </view>
    </view>
  </view>
</view>
