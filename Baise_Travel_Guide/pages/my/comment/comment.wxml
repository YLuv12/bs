<view class="page">
  <view class="header">
    <text class="title">{{lang === 'zh' ? '我的评论' : 'My Comments'}}</text>
  </view>

  <view class="content">
    <view class="item" wx:for="{{list}}" wx:key="id">
      <view class="item-main" bindtap="goToDetail" data-id="{{item.targetId}}" data-type="{{item.type}}">
        <image class="item-img" src="{{item.image}}" mode="aspectFill"/>
        <view class="item-content">
          <view class="item-title">{{item.name}}</view>
          <view class="item-rating">
            <text class="stars">{{item.stars}}</text>
            <text class="score">{{item.score}}分</text>
          </view>
          <view class="item-comment">{{item.content}}</view>
          <view class="item-info">
            <text class="type-tag">{{item.typeText}}</text>
            <text class="time">{{item.time}}</text>
          </view>
        </view>
      </view>
      <view class="item-action" bindtap="deleteComment" data-id="{{item.id}}">
        <text class="delete-text">{{lang === 'zh' ? '删除' : 'Delete'}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{list.length === 0 && !loading}}">
      <text class="empty-text">💬{{lang === 'zh' ? '暂无评论' : 'No comments yet'}}</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>{{lang === 'zh' ? '加载中...' : 'Loading...'}}</text>
  </view>
</view>
