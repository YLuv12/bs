<view class="page">
  <view class="tabs">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">{{lang === 'zh' ? '全部' : 'All'}}</view>
    <view class="tab-item {{activeTab === 'attraction' ? 'active' : ''}}" bindtap="switchTab" data-tab="attraction">{{lang === 'zh' ? '景点' : 'Attractions'}}</view>
    <view class="tab-item {{activeTab === 'food' ? 'active' : ''}}" bindtap="switchTab" data-tab="food">{{lang === 'zh' ? '美食' : 'Food'}}</view>
  </view>

  <view class="content">
    <view class="item" wx:for="{{list}}" wx:key="id">
      <view class="item-main" bindtap="goToDetail" data-id="{{item.targetId}}" data-type="{{item.type}}">
        <image class="item-img" src="{{item.image}}" mode="aspectFill"/>
        <view class="item-content">
          <view class="item-title">{{item.name}}</view>
          <view class="item-info">
            <text class="type-tag">{{item.typeText}}</text>
            <text class="time">{{item.time}}</text>
          </view>
        </view>
      </view>
      <view class="item-action" bindtap="deleteFavorite" data-id="{{item.id}}">
        <text class="delete-text">{{lang === 'zh' ? '取消' : 'Remove'}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{list.length === 0 && !loading}}">
      <text class="empty-text">⭐{{lang === 'zh' ? '暂无收藏' : 'No favorites yet'}}</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>{{lang === 'zh' ? '加载中...' : 'Loading...'}}</text>
  </view>
</view>
