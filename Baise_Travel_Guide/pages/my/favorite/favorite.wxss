.page { min-height: 100vh; background: #F5F6F8; }

.tabs { 
  display: flex; 
  background: #FFFFFF; 
  padding: 20rpx; 
  gap: 20rpx; 
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item { 
  flex: 1; 
  height: 72rpx; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  font-size: 28rpx; 
  color: #8A8AA3; 
  background: #F5F6F8; 
  border-radius: 36rpx; 
}

.tab-item.active { 
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%); 
  color: #FFFFFF; 
}

.content { 
  padding: 20rpx; 
}

.item { 
  display: flex; 
  align-items: center; 
  background: #FFFFFF; 
  border-radius: 16rpx; 
  padding: 20rpx; 
  margin-bottom: 20rpx; 
}

.item-main { 
  flex: 1; 
  display: flex; 
  align-items: center; 
}

.item-img { 
  width: 140rpx; 
  height: 100rpx; 
  border-radius: 12rpx; 
  flex-shrink: 0; 
}

.item-content { 
  flex: 1; 
  margin-left: 20rpx; 
}

.item-title { 
  font-size: 28rpx; 
  font-weight: 500; 
  color: #1A1A2E; 
  margin-bottom: 8rpx; 
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-info { 
  display: flex; 
  align-items: center;
  gap: 12rpx; 
  font-size: 24rpx; 
  color: #8A8AA3; 
}

.type-tag {
  padding: 2rpx 10rpx;
  background: #F5F6F8;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #8A8AA3;
  line-height: 1.4;
}

.time {
  font-size: 22rpx;
  color: #8A8AA3;
}

.item-action { 
  padding: 20rpx; 
}

.delete-text {
  font-size: 24rpx;
  color: #E64340;
}

.empty { 
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0; 
  gap: 10rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8A8AA3;
}

.loading { 
  text-align: center; 
  padding: 40rpx; 
  color: #8A8AA3; 
}
