.page { min-height: 100vh; background: var(--bg-gray); }

.header {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  padding: 60rpx 30rpx 40rpx;
}

.user-info, .login-prompt {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  flex-shrink: 0;
}

.avatar.default {
  opacity: 0.8;
}

.info {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
}

.gender-text {
  padding-top: 27rpx;
  margin-right: 8rpx;
}

.divider {
  margin: 0 8rpx;
  color: rgba(255, 255, 255, 0.5);
}

.intro-text {
  padding-top: 27rpx;
  padding-left: 10rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}

.login-type {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #FFFFFF;
}

.arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

.menu-section {
  background: var(--bg);
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx var(--shadow);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

.action-section {
  background: var(--bg);
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx var(--shadow);
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.action-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.action-value {
  font-size: 26rpx;
  color: var(--text-light);
  margin-right: 10rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

.logout-btn {
  margin: 40rpx 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border-radius: 44rpx;
  font-size: 30rpx;
  color: var(--primary);
  box-shadow: 0 4rpx 20rpx var(--shadow);
}

.version {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: var(--text-light);
}
