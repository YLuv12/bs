<view class="page">
  <view class="header">
    <text class="title">{{lang === 'zh' ? '我的资讯' : 'My News'}}</text>
    <view class="add-btn" bindtap="goToPublish">
      <text class="add-icon">+</text>
      <text>{{lang === 'zh' ? '发布' : 'Publish'}}</text>
    </view>
  </view>

  <view class="content">
    <view class="item" wx:for="{{list}}" wx:key="id">
      <view class="item-main" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="item-img" src="{{item.coverImg}}" mode="aspectFill"/>
        <view class="item-content">
          <view class="item-title">{{item.title}}</view>
          <view class="item-info">
            <text class="read-count">{{lang === 'zh' ? '阅读' : 'Read'}} {{item.readCount}}</text>
            <text class="divider">|</text>
            <text class="time">{{item.createTime}}</text>
          </view>
          <view class="item-tags" wx:if="{{item.tags}}">
            <text class="tag" wx:for="{{item.tags.split(',')}}" wx:for-item="tag" wx:key="index">{{tag}}</text>
          </view>
        </view>
      </view>
      <view class="item-action" bindtap="deleteNews" data-id="{{item.id}}">
        <text class="delete-text">{{lang === 'zh' ? '删除' : 'Delete'}}</text>
      </view>
    </view>

    <view class="empty" wx:if="{{list.length === 0 && !loading}}">
      <text class="empty-icon">📰</text>
      <text class="empty-text">{{lang === 'zh' ? '暂无发布的资讯' : 'No news published'}}</text>
      <view class="empty-btn" bindtap="goToPublish">{{lang === 'zh' ? '发布资讯' : 'Publish News'}}</view>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>{{lang === 'zh' ? '加载中...' : 'Loading...'}}</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">
      <text>{{lang === 'zh' ? '没有更多了' : 'No more'}}</text>
    </view>
  </view>
</view>
