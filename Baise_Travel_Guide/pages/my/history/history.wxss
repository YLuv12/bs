.page { min-height: 100vh; background: #F5F6F8; }

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #FFFFFF;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.clear-btn {
  font-size: 28rpx;
  color: #E64340;
}

.content { 
  padding: 20rpx; 
}

.item { 
  display: flex; 
  align-items: center; 
  background: #FFFFFF; 
  border-radius: 16rpx; 
  padding: 20rpx; 
  margin-bottom: 20rpx; 
}

.item-main { 
  flex: 1; 
  display: flex; 
  align-items: center; 
}

.item-img { 
  width: 140rpx; 
  height: 100rpx; 
  border-radius: 12rpx; 
  flex-shrink: 0; 
}

.item-content { 
  flex: 1; 
  margin-left: 20rpx; 
}

.item-title { 
  font-size: 28rpx; 
  font-weight: 500; 
  color: #1A1A2E; 
  margin-bottom: 8rpx; 
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-info { 
  display: flex; 
  align-items: center;
  gap: 12rpx; 
  font-size: 24rpx; 
  color: #8A8AA3; 
}

.type-tag {
  padding: 2rpx 10rpx;
  background: #F5F6F8;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #8A8AA3;
  line-height: 1.4;
}

.time {
  font-size: 22rpx;
  color: #8A8AA3;
}

.item-action { 
  padding: 20rpx; 
}

.delete-text {
  font-size: 24rpx;
  color: #E64340;
}

.empty { 
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0; 
  gap: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8A8AA3;
}

.loading { 
  text-align: center; 
  padding: 40rpx; 
  color: #8A8AA3; 
}
