.page {
  min-height: 100vh;
  background: #F5F6F8;
  padding-bottom: 120rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: #FFFFFF;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  border: 4rpx solid #E64340;
}

.avatar-tip {
  font-size: 24rpx;
  color: #8A8AA3;
}

.form {
  background: #FFFFFF;
  margin-top: 20rpx;
  padding: 0 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  display: block;
}

.required {
  color: #E64340;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  background: #F5F6F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.picker-input {
  width: 100%;
  height: 80rpx;
  background: #F5F6F8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: #1A1A2E;
}

.picker-arrow {
  font-size: 24rpx;
  color: #8A8AA3;
}

.gender-group {
  display: flex;
  gap: 40rpx;
}

.gender-option {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1A1A2E;
}

.gender-option radio {
  margin-right: 8rpx;
  transform: scale(0.9);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  background: #F5F6F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #8A8AA3;
  margin-top: 8rpx;
}

.save-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(230, 67, 64, 0.3);
}

.save-btn::after {
  border: none;
}

.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 28rpx;
  color: #8A8AA3;
}
