<view class="page">
  <view class="header">
    <text class="title">{{lang === 'zh' ? '反馈记录' : 'Feedback Records'}}</text>
    <view class="add-btn" bindtap="goToSubmit">
      <text class="add-icon">+</text>
      <text>{{lang === 'zh' ? '反馈' : 'Feedback'}}</text>
    </view>
  </view>

  <view class="content">
    <view class="item" wx:for="{{list}}" wx:key="id">
      <view class="item-header">
        <text class="item-type">{{item.type}}</text>
        <text class="item-status {{item.status === 0 ? 'pending' : 'processed'}}">{{item.statusText}}</text>
      </view>
      <view class="item-content">{{item.contentShort}}</view>
      <view class="item-images" wx:if="{{item.imgs.length > 0}}">
        <image class="item-img" wx:for="{{item.imgs}}" wx:for-item="img" wx:key="index" src="{{img}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}" data-imgs="{{item.imgs}}"/>
      </view>
      <view class="item-footer">
        <text class="item-time">{{item.createTime}}</text>
      </view>
      <view class="item-result" wx:if="{{item.handleResult}}">
        <view class="result-title">{{lang === 'zh' ? '处理结果' : 'Result'}}:</view>
        <view class="result-content">{{item.handleResult}}</view>
      </view>
    </view>

    <view class="empty" wx:if="{{list.length === 0 && !loading}}">
      <text class="empty-icon">📝</text>
      <text class="empty-text">{{lang === 'zh' ? '暂无反馈记录' : 'No feedback records'}}</text>
      <view class="empty-btn" bindtap="goToSubmit">{{lang === 'zh' ? '提交反馈' : 'Submit Feedback'}}</view>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>{{lang === 'zh' ? '加载中...' : 'Loading...'}}</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">
      <text>{{lang === 'zh' ? '没有更多了' : 'No more'}}</text>
    </view>
  </view>
</view>
