<view class="page">
  <view class="form-item">
    <view class="form-label">{{lang === 'zh' ? '原密码' : 'Current Password'}}</view>
    <view class="password-input">
      <input class="form-input" password="{{!showOldPassword}}" placeholder="{{lang === 'zh' ? '请输入原密码' : 'Enter current password'}}" value="{{oldPassword}}" bindinput="onOldPasswordInput"/>
      <text class="toggle-pwd" bindtap="toggleShowOldPassword">{{showOldPassword ? '👁️' : '👁️‍🗨️'}}</text>
    </view>
  </view>

  <view class="form-item">
    <view class="form-label">{{lang === 'zh' ? '新密码' : 'New Password'}}</view>
    <view class="password-input">
      <input class="form-input" password="{{!showNewPassword}}" placeholder="{{lang === 'zh' ? '请输入新密码' : 'Enter new password'}}" value="{{newPassword}}" bindinput="onNewPasswordInput"/>
      <text class="toggle-pwd" bindtap="toggleShowNewPassword">{{showNewPassword ? '👁️' : '👁️‍🗨️'}}</text>
    </view>
  </view>

  <view class="form-item">
    <view class="form-label">{{lang === 'zh' ? '确认新密码' : 'Confirm Password'}}</view>
    <view class="password-input">
      <input class="form-input" password="{{!showConfirmPassword}}" placeholder="{{lang === 'zh' ? '请再次输入新密码' : 'Confirm new password'}}" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput"/>
      <text class="toggle-pwd" bindtap="toggleShowConfirmPassword">{{showConfirmPassword ? '👁️' : '👁️‍🗨️'}}</text>
    </view>
  </view>

  <button class="submit-btn" bindtap="submit" loading="{{loading}}">{{lang === 'zh' ? '确认修改' : 'Confirm'}}</button>
</view>
