.page { min-height: 100vh; background: #F5F6F8; padding-bottom: 120rpx; }

.header {
  background: linear-gradient(135deg, #E53935 0%, #FF6B6B 100%);
  padding: 40rpx 30rpx;
  color: #FFFFFF;
}

.title { font-size: 40rpx; font-weight: 600; margin-bottom: 12rpx; }

.desc { font-size: 26rpx; opacity: 0.9; }

.form { padding: 20rpx; }

.form-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  margin-bottom: 16rpx;
}

.required { color: #E53935; margin-left: 4rpx; }

.form-picker {
  width: 100%;
  height: 80rpx;
  background: #F5F6F8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.picker-value { font-size: 28rpx; color: #333333; }

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  background: #F5F6F8;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #8A8AA3;
  margin-top: 8rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: #E53935;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-item.add {
  background: #F5F6F8;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #D0D0D0;
}

.add-icon { font-size: 48rpx; color: #8A8AA3; }

.add-text { font-size: 22rpx; color: #8A8AA3; margin-top: 8rpx; }

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  background: #F5F6F8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.hint {
  padding: 20rpx 30rpx;
  font-size: 24rpx;
  color: #8A8AA3;
}

.submit-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #E53935 0%, #FF6B6B 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.submit-btn::after { border: none; }

.submit-btn.disabled {
  background: #D0D0D0;
}
