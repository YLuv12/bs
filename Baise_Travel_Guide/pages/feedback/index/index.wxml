<view class="page">
  <view class="header">
    <view class="title">{{lang === 'zh' ? '意见反馈' : 'Feedback'}}</view>
    <view class="desc">{{lang === 'zh' ? '您的反馈对我们非常重要' : 'Your feedback is important to us'}}</view>
  </view>

  <view class="form">
    <view class="form-item">
      <view class="form-label">{{lang === 'zh' ? '反馈类型' : 'Type'}}<text class="required">*</text></view>
      <picker class="form-picker" range="{{types}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">{{types[typeIndex].label}} ▾</view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">{{lang === 'zh' ? '反馈内容' : 'Content'}}<text class="required">*</text></view>
      <textarea class="form-textarea" placeholder="{{lang === 'zh' ? '请详细描述您的问题或建议...' : 'Describe your problem or suggestion...'}}" value="{{content}}" bindinput="onContentInput" maxlength="500"/>
      <view class="word-count">{{content.length}}/500</view>
    </view>

    <view class="form-item">
      <view class="form-label">{{lang === 'zh' ? '上传图片' : 'Images'}} ({{lang === 'zh' ? '选填，最多3张' : 'Optional, max 3'}})</view>
      <view class="image-list">
        <view class="image-item" wx:for="{{images}}" wx:key="index">
          <image class="preview-img" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"/>
          <view class="remove-btn" bindtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view class="image-item add" wx:if="{{images.length < 3}}" bindtap="chooseImage">
          <text class="add-icon">+</text>
          <text class="add-text">{{lang === 'zh' ? '添加图片' : 'Add'}}</text>
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">{{lang === 'zh' ? '联系方式' : 'Contact'}} ({{lang === 'zh' ? '选填' : 'Optional'}})</view>
      <input class="form-input" placeholder="{{lang === 'zh' ? '手机号或微信' : 'Phone or WeChat'}}" value="{{contact}}" bindinput="onContactInput"/>
    </view>
  </view>

  <view class="hint">{{lang === 'zh' ? '我们会在1-3个工作日内处理您的反馈' : 'We will process your feedback within 1-3 working days'}}</view>

  <button class="submit-btn {{content.length === 0 ? 'disabled' : ''}}" bindtap="submit" loading="{{submitting}}" disabled="{{content.length === 0 || submitting}}">
    {{submitting ? (lang === 'zh' ? '提交中...' : 'Submitting...') : (lang === 'zh' ? '提交反馈' : 'Submit')}}
  </button>
</view>
