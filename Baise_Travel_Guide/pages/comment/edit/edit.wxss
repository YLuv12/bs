.page { min-height: 100vh; background: var(--bg-gray); padding-bottom: 120rpx; }
.rating-section { background: var(--bg); padding: 40rpx 30rpx; display: flex; flex-direction: column; align-items: center; }
.rating-label { font-size: 28rpx; color: var(--text-secondary); margin-bottom: 20rpx; }
.rating-stars { display: flex; gap: 16rpx; }
.star { font-size: 60rpx; color: #DDD; }
.star.active { color: #FFB800; }
.rating-text { font-size: 28rpx; color: var(--primary); margin-top: 16rpx; font-weight: 500; }
.section { background: var(--bg); padding: 30rpx; margin-top: 20rpx; }
.section-label { font-size: 28rpx; font-weight: 500; color: var(--text); margin-bottom: 20rpx; }
.tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag { padding: 12rpx 24rpx; background: var(--bg-gray); border-radius: 20rpx; font-size: 26rpx; color: var(--text-secondary); }
.tag.active { background: rgba(230, 67, 64, 0.1); color: var(--primary); border: 1rpx solid var(--primary); }
.content-input { width: 100%; height: 200rpx; padding: 20rpx; background: var(--bg-gray); border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; }
.word-count { text-align: right; font-size: 22rpx; color: var(--text-light); margin-top: 10rpx; }
.images { display: flex; flex-wrap: wrap; gap: 20rpx; }
.image-item { position: relative; width: 180rpx; height: 180rpx; border-radius: 12rpx; overflow: hidden; }
.preview { width: 100%; height: 100%; }
.remove { position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; background: rgba(0, 0, 0, 0.5); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #FFF; font-size: 28rpx; }
.image-item.add { background: var(--bg-gray); display: flex; align-items: center; justify-content: center; }
.add-icon { font-size: 48rpx; color: var(--text-light); }
.submit-btn { margin: 30rpx; height: 96rpx; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); border-radius: 48rpx; display: flex; align-items: center; justify-content: center; color: #FFF; font-size: 32rpx; font-weight: 500; border: none; }
.submit-btn::after { border: none; }
