.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%);
}

.header {
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
}

.header-content {
  position: relative;
  padding: 24rpx 32rpx 32rpx;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.6;
}

.clear-icon {
  font-size: 36rpx;
  color: #8A8AA3;
  padding: 0 10rpx;
}

.search-input {
  flex: 1;
  width: 450rpx;
  height: 80rpx;
  font-size: 28rpx;
  background: transparent;
}

.filter-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.filter-text {
  color: #E64340;
  font-size: 24rpx;
}

.sort-tabs {
  display: flex;
  margin-top: 24rpx;
  gap: 8rpx;
}

.sort-item {
  position: relative;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.sort-item.active {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.sort-text {
  font-weight: 500;
}

.sort-indicator {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 4rpx;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.list-content {
  padding: 24rpx 32rpx;
}

.attraction-item {
  display: flex;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 67, 64, 0.08);
  border: 1rpx solid rgba(230, 67, 64, 0.06);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.attraction-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.12);
}

.item-left {
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.item-img-wrap {
  position: relative;
  width: 240rpx;
  height: 200rpx;
}

.item-img {
  width: 100%;
  height: 100%;
}

.item-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
}

.badge-star {
  color: #FFB800;
  font-size: 20rpx;
}

.badge-num {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
}

.item-ticket {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  max-width: 200rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  white-space: normal;
  word-break: break-word;
  text-align: center;
  line-height: 1.3;
  background: #E64340;
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(230, 67, 64, 0.3);
}

.item-content {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.item-title-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  line-height: 1.3;
  word-break: break-all;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.tag.red {
  background: linear-gradient(135deg, rgba(230, 67, 64, 0.12) 0%, rgba(255, 107, 107, 0.12) 100%);
  color: #E64340;
}

.tag.nature {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.12) 0%, rgba(129, 199, 132, 0.12) 100%);
  color: #4CAF50;
}

.tag.ethnic {
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.12) 0%, rgba(186, 104, 200, 0.12) 100%);
  color: #9C27B0;
}

.item-info-row {
  margin-bottom: 8rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #8A8AA3;
}

.info-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.info-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-footer {
  padding-left: 50rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.footer-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.footer-icon {
  font-size: 22rpx;
}

.footer-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.footer-label {
  font-size: 20rpx;
  color: #8A8AA3;
}

.footer-divider {
  width: 1rpx;
  height: 24rpx;
  background: rgba(0, 0, 0, 0.06);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #8A8AA3;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(230, 67, 64, 0.2);
  border-top-color: #E64340;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8A8AA3;
}

.reach-bottom {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 20rpx;
}

.reach-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.1), transparent);
}

.reach-text {
  font-size: 24rpx;
  color: #8A8AA3;
}

.back-top {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
  visibility: hidden;
  transform: scale(0.8);
  animation: pulse 2s ease-in-out infinite;
}

.back-top.show {
  opacity: 1;
  visibility: visible;
  transform: scale(1);
}

.back-top.hide {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: scale(0.8);
}

.back-top:active {
  transform: scale(0.9);
}

.back-top-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-top-arrow text {
  color: #E64340;
  font-size: 36rpx;
  font-weight: 700;
}

@keyframes pulse {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.05);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  visibility: hidden;
}

.filter-panel.show {
  visibility: visible;
}

.filter-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.filter-content {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 75%;
  background: #FFFFFF;
  padding: 32rpx;
  box-sizing: border-box;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.filter-panel.show .filter-content {
  transform: translateX(0);
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.filter-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.filter-clear {
  font-size: 28rpx;
  color: #E64340;
  font-weight: 500;
}

.filter-section {
  padding: 32rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.filter-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 20rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  padding: 16rpx 28rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #4A4A68;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.active {
  background: rgba(230, 67, 64, 0.08);
  color: #E64340;
  border-color: #E64340;
}

.filter-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.filter-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.filter-btn.cancel {
  background: rgba(0, 0, 0, 0.03);
  color: #4A4A68;
}

.filter-btn.confirm {
  background: linear-gradient(135deg, #E64340 0%, #FF6B6B 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(230, 67, 64, 0.3);
}

.animate-fade-up {
  animation: fadeUp 0.4s ease-out forwards;
  opacity: 0;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
