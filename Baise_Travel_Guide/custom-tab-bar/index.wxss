.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(248, 249, 250, 0.98);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 32rpx rgba(0, 0, 0, 0.06);
  z-index: 9999;
}

.tab-bar-border {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.06), transparent);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  transition: all 0.3s ease;
}

.tab-bar-item:active {
  background: rgba(229, 57, 53, 0.05);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
  transition: transform 0.3s ease;
}

.tab-bar-item:active .tab-icon {
  transform: scale(0.9);
}

.tab-text {
  font-size: 22rpx;
  font-weight: 500;
  transition: color 0.3s ease;
}

.center-item {
  position: relative;
  margin-top: -40rpx;
}

.center-btn {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #E53935 0%, #FF6B6B 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(229, 57, 53, 0.4);
  transition: all 0.3s ease;
}

.center-item:active .center-btn {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(229, 57, 53, 0.5);
}

.center-icon {
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}
