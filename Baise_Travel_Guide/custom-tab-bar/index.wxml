<view class="tab-bar">
  <view class="tab-bar-border"></view>
  <view wx:for="{{list}}" wx:key="index" class="tab-bar-item {{item.center ? 'center-item' : ''}}" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <view wx:if="{{item.center}}" class="center-btn">
      <text class="center-icon">+</text>
    </view>
    <block wx:else>
      <image src="{{selected === index ? item.selectedIconPath : item.iconPath}}" class="tab-icon"></image>
      <view class="tab-text" style="color: {{selected === index ? selectedColor : color}}">
        {{lang === 'zh' ? item.text : item.textEn}}
      </view>
    </block>
  </view>
</view>
